# ── Pipedrive ───────────────────────────────────────
# Your API token from Pipedrive Settings > Personal Preferences > API
PIPEDRIVE_API_TOKEN=
# Your Pipedrive subdomain (e.g. "yourcompany" from yourcompany.pipedrive.com)
PIPEDRIVE_COMPANY_DOMAIN=

# ── Gmail OAuth 2.0 ────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/oauth2callback

# ── Slack ───────────────────────────────────────────
# Create an Incoming Webhook at https://api.slack.com/apps
SLACK_WEBHOOK_URL=

# ── Anthropic (optional) ───────────────────────────
# Enables AI-powered email personalization
ANTHROPIC_API_KEY=

# ── Schedule ────────────────────────────────────────
# Cron expression for --schedule mode (default: 7am weekdays)
CRON_SCHEDULE=0 7 * * 1-5

# ── Agent Settings ──────────────────────────────────
# Your name as it appears in email signatures
SENDER_NAME=
# Your email address (used as Gmail sender)
SENDER_EMAIL=
# Fund name injected into templates
FUND_NAME=
